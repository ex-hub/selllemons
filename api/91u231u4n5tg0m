	Row.Name = labelText
	Row.Size = UDim2.new(1, 0, 0, TOGGLE_H)
	Row.BackgroundColor3 = Color3.fromRGB(22, 22, 22)
	Row.BackgroundTransparency = 0
	Row.BorderSizePixel = 0
	Row.LayoutOrder = layoutOrder
	Row.Parent = parent

	Instance.new("UICorner", Row).CornerRadius = UDim.new(0, 8)

	local RowStroke = Instance.new("UIStroke")
	RowStroke.Thickness = 1
	RowStroke.Color = Color3.fromRGB(45, 45, 45)
	RowStroke.Transparency = 0
	RowStroke.Parent = Row

	--// Left accent bar per row
	local RowPill = Instance.new("Frame")
	RowPill.Size = UDim2.new(0, 2, 0, 18)
	RowPill.Position = UDim2.new(0, 10, 0.5, -9)
	RowPill.BackgroundColor3 = Color3.fromRGB(140, 140, 140)
	RowPill.BackgroundTransparency = 0.4
	RowPill.BorderSizePixel = 0
	RowPill.Parent = Row

	Instance.new("UICorner", RowPill).CornerRadius = UDim.new(1, 0)

	local Label = Instance.new("TextLabel")
	Label.Size = UDim2.new(1, -70, 1, 0)
	Label.Position = UDim2.new(0, 20, 0, 0)
	Label.BackgroundTransparency = 1
	Label.Text = labelText
	Label.TextColor3 = Color3.fromRGB(200, 200, 200)
	Label.TextSize = 13
	Label.Font = Enum.Font.Gotham
	Label.TextXAlignment = Enum.TextXAlignment.Left
	Label.Parent = Row

	--// Toggle track
	local ToggleHolder = Instance.new("Frame")
	ToggleHolder.Size = UDim2.new(0, 40, 0, 22)
	ToggleHolder.Position = UDim2.new(1, -52, 0.5, -11)
	ToggleHolder.BackgroundColor3 = Color3.fromRGB(38, 38, 38)
	ToggleHolder.BorderSizePixel = 0
	ToggleHolder.Parent = Row

	Instance.new("UICorner", ToggleHolder).CornerRadius = UDim.new(1, 0)

	local TrackStroke = Instance.new("UIStroke")
	TrackStroke.Thickness = 1
	TrackStroke.Color = Color3.fromRGB(55, 55, 55)
	TrackStroke.Transparency = 0
	TrackStroke.Parent = ToggleHolder

	--// Knob
	local ToggleKnob = Instance.new("Frame")
	ToggleKnob.Size = UDim2.new(0, 16, 0, 16)
	ToggleKnob.Position = UDim2.new(0, 3, 0.5, -8)
	ToggleKnob.BackgroundColor3 = Color3.fromRGB(90, 90, 90)
	ToggleKnob.BorderSizePixel = 0
	ToggleKnob.Parent = ToggleHolder

	Instance.new("UICorner", ToggleKnob).CornerRadius = UDim.new(1, 0)

	local toggled = false

	local ToggleButton = Instance.new("TextButton")
	ToggleButton.Size = UDim2.new(1, 0, 1, 0)
	ToggleButton.BackgroundTransparency = 1
	ToggleButton.Text = ""
	ToggleButton.Parent = Row

	ToggleButton.MouseButton1Click:Connect(function()
		toggled = not toggled

		local knobPos = toggled and UDim2.new(1, -19, 0.5, -8) or UDim2.new(0, 3, 0.5, -8)
		local trackColor = toggled and Color3.fromRGB(65, 65, 65) or Color3.fromRGB(38, 38, 38)
		local knobColor = toggled and Color3.fromRGB(220, 220, 220) or Color3.fromRGB(90, 90, 90)
		local pillColor = toggled and Color3.fromRGB(210, 210, 210) or Color3.fromRGB(140, 140, 140)

		TweenService:Create(ToggleKnob, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {
			Position = knobPos,
			BackgroundColor3 = knobColor,
		}):Play()

		TweenService:Create(ToggleHolder, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {
			BackgroundColor3 = trackColor,
		}):Play()

		TweenService:Create(RowPill, TweenInfo.new(0.18, Enum.EasingStyle.Quad), {
			BackgroundColor3 = pillColor,
			BackgroundTransparency = toggled and 0 or 0.4,
		}):Play()

		callback(toggled)

		--// Notification
		local Notif = Instance.new("Frame")
		Notif.Size = UDim2.new(0, 210, 0, 34)
		Notif.Position = UDim2.new(0.5, -105, 1, 10)
		Notif.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
		Notif.BackgroundTransparency = 0.05
		Notif.BorderSizePixel = 0
		Notif.ZIndex = 10
		Notif.Parent = ScreenGui

		Instance.new("UICorner", Notif).CornerRadius = UDim.new(0, 7)

		local NStroke = Instance.new("UIStroke")
		NStroke.Thickness = 1
		NStroke.Color = toggled and Color3.fromRGB(160, 160, 160) or Color3.fromRGB(55, 55, 55)
		NStroke.Transparency = 0.3
		NStroke.Parent = Notif

		local NLabel = Instance.new("TextLabel")
		NLabel.Size = UDim2.new(1, 0, 1, 0)
		NLabel.BackgroundTransparency = 1
		NLabel.Text = labelText .. "  ·  " .. (toggled and "Enabled" or "Disabled")
		NLabel.TextColor3 = toggled and Color3.fromRGB(220, 220, 220) or Color3.fromRGB(120, 120, 120)
		NLabel.TextSize = 12
		NLabel.Font = Enum.Font.Gotham
		NLabel.ZIndex = 10
		NLabel.Parent = Notif

		TweenService:Create(Notif, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
			Position = UDim2.new(0.5, -105, 1, -46),
		}):Play()

		task.wait(2)

		TweenService:Create(Notif, TweenInfo.new(0.25, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {
			Position = UDim2.new(0.5, -105, 1, 10),
		}):Play()

		task.wait(0.3)
		Notif:Destroy()
	end)
end

